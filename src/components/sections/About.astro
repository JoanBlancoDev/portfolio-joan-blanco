---
// TODO: Resumen profesional centrado en resolución de problemas
import memojiVideo from "../../assets/memoji.webm";
import { profile } from "../../data/portfolio";
---

<section
  id="about"
  aria-label="Sobre mí"
  data-i18n-aria="about.aria"
  class="container-section flex flex-col lg:flex-row gap-12 md:gap-24"
>
  <article class="flex-2">
    <h2 data-i18n="nav.about" class="section-heading font-extrabold">Sobre Mí</h2>
    <p data-i18n="about.summary" class="text-pretty font-light leading-relaxed text-normal md:text-xl mt-8">
      {profile.summary.es}
    </p>
  </article>

  <div class="flex flex-1 justify-center items-center" aria-hidden="true">
  <div class="relative group">
    
    {/* 1. Resplandor de fondo usando tu --color-primary */}
    <div 
      class="absolute -inset-4 rounded-full opacity-20 blur-2xl transition duration-1000 group-hover:opacity-40 group-hover:duration-500 pointer-events-none"
      style="background: var(--color-primary);"
    ></div>

    {/* 2. Contenedor del video con borde de tu paleta */}
    <div class="relative rounded-full p-1 border border-(--glass-border) bg-(--card-bg) shadow-2xl overflow-hidden">
      
      <video
        id="about-memoji-video"
        class="w-60 h-60 md:w-80 md:h-80 object-cover rounded-full mix-blend-screen brightness-110 contrast-110"
        autoplay 
        muted
        loop
        playsinline
        disablepictureinpicture
      >
        <source src={memojiVideo} type="video/webm" />
      </video>

      {/* 3. El "Velo" de Integración (Opcional si aún ves un borde) */}
      <div 
        class="absolute inset-0 rounded-full pointer-events-none"
        style="background: radial-gradient(circle, transparent 50%, var(--color-bg) 100%);"
      ></div>
    </div>
  </div>
</div>
</section>

<script is:inline>
  const video = document.getElementById("about-memoji-video");
  const aboutSection = document.getElementById("about");
  const reduceMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  if (video instanceof HTMLVideoElement && aboutSection && !reduceMotion) {
    const observer = new IntersectionObserver(
      (entries) => {
        const entry = entries[0];
        if (!entry) return;

        if (entry.isIntersecting) {
          void video.play().catch(() => {});
        } else {
          video.pause();
        }
      },
      { threshold: 0.35 },
    );

    observer.observe(aboutSection);
  }
</script>
