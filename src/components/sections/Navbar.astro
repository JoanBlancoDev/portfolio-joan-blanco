---
const links = [
  { href: "#about", label: "Sobre Mi", i18nKey: "nav.about" },
  { href: "#experience", label: "Experiencia", i18nKey: "nav.experience" },
  { href: "#projects", label: "Proyectos", i18nKey: "nav.projects" },
  { href: "#skills", label: "Habilidades", i18nKey: "nav.skills" },
  { href: "#contact", label: "Contacto", i18nKey: "nav.contact" },
];
---

<header class="navbar-shell relative z-50">
  <nav
    id="top"
    aria-label="Navegación principal"
    data-i18n-aria="nav.aria.primary"
    class="navbar-fixed fixed top-4 left-1/2 -translate-x-1/2 z-50 w-[min(1120px,80%)] flex justify-between items-center gap-4 glass-panel animate-fade-down"
  >
    <a class="text-xl sm:text-2xl hidden lg:inline" href="#hero">
      <span class="text-secondary">{"<"}</span>

      <span class="font-bold italic">JD</span>
      <span class="text-secondary">{"/>"}</span>
    </a>

    <ul class="gap-8 justify-center  items-center hidden lg:flex">
      {
        links.map((link) => (
          <li>
            <a class="nav-link" href={link.href} data-i18n={link.i18nKey}>
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center w-full justify-between gap-2 lg:w-auto lg:justify-normal">
      <!-- Switch Language -->
      <button
        id="lang-toggle"
        type="button"
        class="btn-outline py-2 px-3 text-sm"
        aria-label="Cambiar idioma"
        data-i18n-aria="nav.langToggle.aria"
      >
        EN
      </button>

      <button
        id="mobile-nav-toggle"
        type="button"
        class="mobile-nav-toggle lg:hidden ml-3 z-20 self-center flex items-center justify-center"
        aria-label="Abrir menú de navegación"
        data-i18n-aria="sidebar.openMenu"
        aria-expanded="false"
        aria-controls="mobile-nav-drawer"
        data-expanded="false"
      >
        <span class="mobile-nav-toggle-icon" aria-hidden="true">
          <span class="mobile-nav-toggle-swap">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="4" y1="6" x2="20" y2="6"></line>
              <line x1="4" y1="12" x2="20" y2="12"></line>
              <line x1="4" y1="18" x2="20" y2="18"></line>
            </svg>
          </span>
          <span class="mobile-nav-toggle-swap is-hidden">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </span>
        </span>
      </button>
    </div>

    <aside
      id="mobile-nav-drawer"
      data-open="false"
      class="mobile-nav-drawer lg:hidden fixed top-0 left-0 z-10 flex h-[70vh] w-full flex-col items-center justify-center p-8 shadow-2xl"
      aria-hidden="true"
      inert
    >
      <div class="mb-8 flex flex-col items-center">
        <a class="text-2xl font-bold italic flex items-center gap-2" href="#hero" aria-label="Inicio">
          <span class="text-secondary">{"<"}</span>
          <span>JD</span>
          <span class="text-secondary">{"/>"}</span>
        </a>
      </div>
      <nav aria-label="Móvil" class="mobile-nav-drawer-inner w-full">
        <ul class="flex w-full flex-col items-center gap-6">
          {
            links.map((link) => (
              <li class="mobile-nav-link-stagger">
                <a
                  href={link.href}
                  class="text-2xl font-semibold transition-colors duration-200 hover:text-(--color-accent)"
                  style="color: var(--color-text-high)"
                  data-i18n={link.i18nKey}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </aside>
  </nav>
</header>

<script is:inline>
  const setupNavbarScrollSpy = () => {
    const nav = document.getElementById("top");
    const mobileToggle = document.getElementById("mobile-nav-toggle");
    const mobileDrawer = document.getElementById("mobile-nav-drawer");
    const mobileLinks = Array.from(
      document.querySelectorAll('#mobile-nav-drawer a[href^="#"]'),
    );
    const navLinks = Array.from(
      document.querySelectorAll('a.nav-link[href^="#"]'),
    );
    const sections = navLinks
      .map((link) => {
        const id = link.getAttribute("href")?.slice(1);
        if (!id) return null;
        const section = document.getElementById(id);
        return section ? { id, section, link } : null;
      })
      .filter(Boolean);

    const getActivationOffset = () => {
      const firstSection = sections[0]?.section;
      if (!firstSection) return 0;
      const scrollMarginTop = Number.parseFloat(
        getComputedStyle(firstSection).scrollMarginTop || "0",
      );
      return Number.isNaN(scrollMarginTop) ? 0 : scrollMarginTop;
    };

    const applyActiveState = (activeId) => {
      for (const item of sections) {
        const isActive = Boolean(activeId && item.id === activeId);
        item.link.classList.toggle("is-active", isActive);
        if (isActive) {
          item.link.setAttribute("aria-current", "true");
        } else {
          item.link.removeAttribute("aria-current");
        }
      }
    };

    const setActiveLink = () => {
      if (!sections.length) return;

      const activationOffset = getActivationOffset();
      const y = window.scrollY + activationOffset;
      const viewportBottom = window.scrollY + window.innerHeight;
      const documentHeight = document.documentElement.scrollHeight;

      if (viewportBottom >= documentHeight - 2) {
        applyActiveState(sections[sections.length - 1]?.id ?? null);
        return;
      }

      let current = null;
      for (const item of sections) {
        const top = item.section.offsetTop;
        const bottom = top + item.section.offsetHeight;

        if (y >= top) current = item;
        if (y >= top && y < bottom) {
          current = item;
          break;
        }
      }

      applyActiveState(current?.id ?? null);
    };

    const setScrolledState = () => {
      if (!nav) return;
      nav.classList.toggle("is-scrolled", window.scrollY > 12);
    };

    const onScroll = () => {
      setScrolledState();
      setActiveLink();
    };

    const onNavClick = (event) => {
      const target = event.currentTarget;
      if (!(target instanceof HTMLAnchorElement)) return;
      const id = target.getAttribute("href")?.slice(1);
      if (!id) return;
      applyActiveState(id);
    };

    const setMobileState = (open) => {
      if (
        !(mobileToggle instanceof HTMLButtonElement) ||
        !(mobileDrawer instanceof HTMLElement)
      )
        return;

      mobileToggle.setAttribute("aria-expanded", String(open));
      mobileToggle.dataset.expanded = open ? "true" : "false";

      mobileDrawer.dataset.open = open ? "true" : "false";
      mobileDrawer.setAttribute("aria-hidden", open ? "false" : "true");
      if (open) {
        mobileDrawer.removeAttribute("inert");
      } else {
        mobileDrawer.setAttribute("inert", "");
      }

      const swaps = mobileToggle.querySelectorAll(".mobile-nav-toggle-swap");
      const first = swaps[0];
      const second = swaps[1];
      if (first instanceof HTMLElement)
        first.classList.toggle("is-hidden", open);
      if (second instanceof HTMLElement)
        second.classList.toggle("is-hidden", !open);

      const key = open ? "sidebar.closeMenu" : "sidebar.openMenu";
      const translated = window.i18next?.isInitialized
        ? window.i18next.getFixedT(
            document.documentElement.dataset.lang === "en" ? "en" : "es",
          )(key)
        : open
          ? "Cerrar menú de navegación"
          : "Abrir menú de navegación";
      mobileToggle.setAttribute("aria-label", translated);
    };

    if (
      mobileToggle instanceof HTMLButtonElement &&
      mobileDrawer instanceof HTMLElement
    ) {
      mobileToggle.addEventListener("click", () => {
        const isOpen = mobileDrawer.dataset.open === "true";
        setMobileState(!isOpen);
      });

      for (const link of mobileLinks) {
        link.addEventListener("click", () => setMobileState(false));
      }

      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && mobileDrawer.dataset.open === "true") {
          setMobileState(false);
        }
      });

      window.addEventListener("app:lang-change", () => {
        const isOpen = mobileDrawer.dataset.open === "true";
        setMobileState(isOpen);
      });
    }

    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
    window.addEventListener("hashchange", setActiveLink);

    for (const link of navLinks) {
      link.addEventListener("click", onNavClick);
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupNavbarScrollSpy, {
      once: true,
    });
  } else {
    setupNavbarScrollSpy();
  }
</script>
