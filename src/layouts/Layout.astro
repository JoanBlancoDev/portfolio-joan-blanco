---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Joan Blanco | Fullstack Web Developer',
  description = 'Portfolio de Joan Blanco — Fullstack Web Developer especializado en React, Node.js, Astro y TypeScript. Proyectos reales, código limpio y enfoque en producto.',
  ogImage = '/og-image.png',
} = Astro.props;
---

<!doctype html>
<html lang="es" data-theme="b" data-mode="dark" data-lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href="https://joanblanco.dev/" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://joanblanco.dev/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Preload critical fonts (woff2 subset for Inter Variable) -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/inter-variable.woff2"
      crossorigin="anonymous"
    />
  </head>
  <body>
    <slot />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        root.dataset.theme = 'b';

        const savedMode = localStorage.getItem('mode');
        if (savedMode === 'light' || savedMode === 'dark') {
          root.dataset.mode = savedMode;
        } else {
          root.dataset.mode = 'dark';
        }

        window.toggleColorMode = () => {
          const nextMode = root.dataset.mode === 'light' ? 'dark' : 'light';
          root.dataset.mode = nextMode;
          localStorage.setItem('mode', nextMode);
        };
      })();
    </script>

    <script>
      import { initI18n } from '../scripts/i18n';
      import { translations } from '../constants/translations';

      initI18n(translations);
    </script>
  </body>
</html>
